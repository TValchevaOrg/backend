# Backend configuration template. Copy to .env (or .env.local) and edit:
#   cp .env.example .env
# Both files are git-ignored; this committed file is the reference contract.
#
# The database variables intentionally reuse the transform pipeline's FOODIE_DB_*
# names, so a single set of credentials feeds both the writer (transform) and
# this reader (backend). Anything already set in the real environment wins.

# --- PostgreSQL connection (the catalog data source) ----------------------- #
# Set a full DSN, or leave it blank and supply the individual parts below.
# FOODIE_DB_DSN=postgresql://foodie:foodie@localhost:5432/foodie
FOODIE_DB_HOST=localhost
FOODIE_DB_PORT=5432
FOODIE_DB_NAME=foodie
FOODIE_DB_USER=foodie
FOODIE_DB_PASSWORD=foodie
FOODIE_DB_SSLMODE=prefer

# --- API server ------------------------------------------------------------ #
# Comma-separated list of allowed browser origins (the Vite dev server, etc.).
FOODIE_API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FOODIE_API_LOG_LEVEL=INFO

# Connection-pool sizing for the read workload.
FOODIE_API_POOL_MIN_SIZE=1
FOODIE_API_POOL_MAX_SIZE=10
